# Copy to .env.local. Get values from `supabase status` after `supabase start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:56321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Used to build links in subscriber emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: email subscribers to a suggestion when it gets a new comment or
# status change. Leave unset to skip sending (logs instead).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Set to "true" to skip actually sending emails even when RESEND_API_KEY is
# set (still logs what would've been sent). Handy for local dev so testing
# doesn't spam real inboxes. Leave unset/false in production.
DISABLE_EMAILS=false
